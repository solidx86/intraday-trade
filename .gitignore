.DS_Store

# Claude Code project-local state — per-machine settings (settings.local.json
# is intentionally machine-specific) and transient agent worktrees.
.claude/

# Skill-creator eval workspaces — dev artefacts, regenerated by eval runs
*-workspace/

# Private repo mounts — journal + framework, symlinked in (see README.md)
data/trade-journal
data/framework
__pycache__/

# Pre-publish IP-abstraction review artifacts (design/plan HTML) — never publish
review-artifacts/

# Internal working docs (design specs + implementation plans) — kept local, not published
/docs/superpowers/
